# Environment
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/bgv_db
DATABASE_SYNC_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/bgv_db

# Google OAuth2 (required for authentication)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest
OLLAMA_CONNECT_TIMEOUT=10.0
OLLAMA_MAX_RETRIES=3
OLLAMA_NUM_PREDICT=1024
OLLAMA_NUM_CTX=8192

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,webp
MAX_FILES_PER_UPLOAD=20

# Security
SECRET_KEY=change-this-to-a-secure-random-string-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Processing
MAX_CONCURRENT_OCR=2
MAX_CONCURRENT_AI=1
OCR_TIMEOUT_SECONDS=120
AI_TIMEOUT_SECONDS=120

# Task Management
MAX_DOCUMENT_CONCURRENCY=4
MAX_BATCH_CONCURRENCY=2
MAX_NOTIFICATION_CONCURRENCY=4
SHUTDOWN_TIMEOUT_SECONDS=30

# OpenAI (fallback validation — optional)
OPENAI_API_KEY=
OPENAI_ENABLED=false
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=2
OPENAI_TIMEOUT_SECONDS=30
OPENAI_FALLBACK_MIN_OCR_CONFIDENCE=0.3
OPENAI_FALLBACK_MIN_CLASSIFICATION_CONFIDENCE=0.5
OPENAI_FALLBACK_MAX_OWNERSHIP_SCORE=80.0

# Session Cookie
SESSION_COOKIE_NAME=bgv_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

# WebSocket
WS_TICKET_TTL_SECONDS=30

# Dashboard
DASHBOARD_CACHE_TTL_SECONDS=30

# Notifications
EMAIL_MAX_RETRIES=3
STUCK_NOTIFICATION_MAX_AGE_MINUTES=30

# Google API I/O
GOOGLE_IO_POOL_SIZE=4

# OS Fixes
KMP_DUPLICATE_LIB_OK=TRUE
